<UserControl x:Class="MiniIDEv04.Controls.GitHubPushPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:ctl="clr-namespace:MiniIDEv04.Controls"
             Cursor="SizeAll"
             MinWidth="420">
    <Border BorderBrush="#44000000" BorderThickness="1" CornerRadius="4"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{Binding TitleBarBrush, RelativeSource={RelativeSource AncestorType=ctl:GitHubPushPanelControl}}"
                    CornerRadius="4,4,0,0">
                <TextBlock Text="{Binding PanelTitle, RelativeSource={RelativeSource AncestorType=ctl:GitHubPushPanelControl}}"
                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="8,0"/>
            </Border>

            <!-- WrapPanel row: position label + Pull + Push -->
            <WrapPanel Grid.Row="1"
                       Orientation="Horizontal"
                       Height="30"
                       Background="#FFF0F0F0"
                       Margin="0">
                <TextBox x:Name="PositionLabel"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="9" FontFamily="Consolas"
                         Foreground="#FF666666"
                         VerticalAlignment="Center"
                         MinWidth="70"
                         Padding="6,0,6,0"
                         Margin="0,0,4,0"
                         Text="(0, 0)"/>
                <telerik:RadButton Content="⬇ Pull"
                    Width="60" Height="22"
                    Margin="0,4,4,4"
                    FontSize="10"
                    Click="PullButton_Click"
                    ToolTip="git pull origin main"/>
                <telerik:RadButton Content="⬆ Push"
                    Width="60" Height="22"
                    Margin="0,4,4,4"
                    FontSize="10"
                    Style="{StaticResource AddButtonStyle}"
                    Click="QuickPushButton_Click"
                    ToolTip="git push origin main (no commit)"/>
            </WrapPanel>

            <!-- Commit input row -->
            <Grid Grid.Row="2" Margin="6,6,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <telerik:RadWatermarkTextBox Grid.Column="0"
                    x:Name="CommitMessageBox"
                    WatermarkContent="Commit message..."
                    Background="#FFF0F8FF"
                    Margin="0,0,4,0"/>
                <telerik:RadWatermarkTextBox Grid.Column="1"
                    x:Name="VersionTagBox"
                    WatermarkContent="v4.x.x"
                    Background="#FFF0F8FF"
                    Margin="0,0,4,0"/>
                <telerik:RadButton Grid.Column="2"
                    Content="🐙 Commit+Push"
                    Style="{StaticResource AddButtonStyle}"
                    Click="PushButton_Click"/>
            </Grid>

            <!-- Output log -->
            <Border Grid.Row="3" Margin="6,0,6,6"
                    BorderBrush="#FFD0D0D0" BorderThickness="1"
                    Background="#FF1E1E1E" CornerRadius="2">
                <ScrollViewer x:Name="LogScroller"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogOutput"
                               FontFamily="Consolas" FontSize="9"
                               Foreground="#FF90EE90"
                               Padding="6,4"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
