<UserControl x:Class="MiniIDEv04.Controls.SysManagerLauncherControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:MiniIDEv04.Controls"
             Cursor="SizeAll">
    <Border BorderBrush="#44000000" BorderThickness="1" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{Binding TitleBarBrush, RelativeSource={RelativeSource AncestorType=ctl:SysManagerLauncherControl}}"
                    CornerRadius="4,4,0,0">
                <TextBlock Text="{Binding PanelTitle, RelativeSource={RelativeSource AncestorType=ctl:SysManagerLauncherControl}}"
                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="8,0"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <Border Grid.Row="1" x:Name="PositionBorder"
                    Background="#FFF0F0F0" BorderBrush="#FFD0D0D0"
                    BorderThickness="0,0,0,1" Visibility="Collapsed">
                <TextBlock x:Name="PositionLabel" FontSize="8" FontFamily="Consolas"
                           Foreground="#FF666666" Padding="6,2,6,2"/>
            </Border>

            <Border Grid.Row="2" Background="#FF263238">
                <Viewbox Width="38" Height="38"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Stretch="Uniform">
                    <Path Fill="White"
                          Data="M 28 4 C 22 4 17 8 16 14 L 2 28 C 0 30 0 33 2 35 L 5 38 C 7 40 10 40 12 38 L 26 24 C 32 23 36 18 36 12 C 36 10 35 8 34 6 L 28 12 L 24 8 Z M 6 33 C 6 34 5 35 4 35 C 3 35 2 34 2 33 C 2 32 3 31 4 31 C 5 31 6 32 6 33 Z"/>
                </Viewbox>
            </Border>
        </Grid>
    </Border>
</UserControl>
