<UserControl x:Class="MiniIDEv04.Controls.ucProjectZip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">

    <UserControl.Resources>

        <Style x:Key="ZipButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#FF1565C0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#FF0D47A1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#FF455A64"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF37474F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border Background="#FF0D1B26"
            BorderBrush="#FF263238"
            BorderThickness="1"
            CornerRadius="5"
            Padding="12,8">

        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">

            <!-- Title label -->
            <TextBlock Text="PROJECT BACKUP"
                       Foreground="#FF607D8B"
                       FontSize="8"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>

            <!-- Zip button -->
            <Button x:Name="ZipButton"
                    Content="🗜  Zip Project"
                    Style="{StaticResource ZipButtonStyle}"
                    ToolTip="Zips all project files (excludes bin\ and obj\) to the project root folder"
                    Click="ZipButton_Click"/>

            <!-- Status line -->
            <TextBlock x:Name="StatusText"
                       Text=""
                       Foreground="#FF80CBC4"
                       FontSize="10"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="260"
                       Margin="0,6,0,0"
                       Visibility="Collapsed"/>

        </StackPanel>
    </Border>

</UserControl>
