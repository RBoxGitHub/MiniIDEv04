<UserControl
    x:Class="MiniIDEv04.Controls.QuickAddPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:ctl="clr-namespace:MiniIDEv04.Controls">

    <Border BorderBrush="#44000000"
            BorderThickness="1"
            CornerRadius="4"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ──────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{Binding TitleBarBrush,
                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CornerRadius="4,4,0,0">
                <TextBlock Text="{Binding PanelTitle,
                               RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="White"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
            </Border>

            <!-- ── Position label ─────────────────────────────────────── -->
            <Border Grid.Row="1"
                    x:Name="PositionBorder"
                    Background="#FFF0F0F0"
                    BorderBrush="#FFD0D0D0"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                <TextBlock x:Name="PositionLabel"
                           FontSize="8" FontFamily="Consolas"
                           Foreground="#FF666666"
                           Padding="6,2,6,2"/>
            </Border>

            <!-- ── Body ───────────────────────────────────────────────── -->
            <Grid Grid.Row="2" Margin="4,4,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <telerik:RadWatermarkTextBox Grid.Column="0"
                    WatermarkContent="Add Next Idea or Project..."
                    Text="{Binding NewNoteText, UpdateSourceTrigger=PropertyChanged}"
                    Background="#FFF0F8FF"
                    Margin="0,0,4,0"/>

                <telerik:RadComboBox Grid.Column="1" Margin="0,0,4,0"
                    SelectedIndex="{Binding NewNotePhase,
                        Converter={StaticResource IntOffsetConverter},
                        ConverterParameter=-1}"
                    ToolTip="Phase">
                    <telerik:RadComboBoxItem Content="Phase 1"/>
                    <telerik:RadComboBoxItem Content="Phase 2"/>
                    <telerik:RadComboBoxItem Content="Phase 3"/>
                    <telerik:RadComboBoxItem Content="Phase 4"/>
                </telerik:RadComboBox>

                <telerik:RadComboBox Grid.Column="2" Margin="0,0,4,0"
                    SelectedIndex="{Binding NewNotePriority,
                        Converter={StaticResource IntOffsetConverter},
                        ConverterParameter=-1}"
                    ToolTip="Priority">
                    <telerik:RadComboBoxItem Content="High"/>
                    <telerik:RadComboBoxItem Content="Normal"/>
                    <telerik:RadComboBoxItem Content="Low"/>
                </telerik:RadComboBox>

                <telerik:RadButton Grid.Column="3"
                    Content="+ Add"
                    Style="{StaticResource AddButtonStyle}"
                    Click="AddButton_Click"/>
            </Grid>

        </Grid>
    </Border>
</UserControl>
