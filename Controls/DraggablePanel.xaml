<UserControl x:Class="MiniIDEv04.Controls.DraggablePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:MiniIDEv04.Controls"
             Cursor="SizeAll">

    <Border BorderBrush="#44000000"
            BorderThickness="1"
            CornerRadius="4"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ──────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{Binding TitleBarBrush,
                        RelativeSource={RelativeSource AncestorType=ctl:DraggablePanel}}"
                    CornerRadius="4,4,0,0">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding PanelTitle,
                                   RelativeSource={RelativeSource AncestorType=ctl:DraggablePanel}}"
                               Foreground="White"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1"
                            Content="✕"
                            Width="18" Height="18"
                            FontSize="9"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            Click="CloseButton_Click"
                            Visibility="{Binding ShowCloseButton,
                                RelativeSource={RelativeSource AncestorType=ctl:DraggablePanel},
                                Converter={StaticResource BoolToVisConverter}}"/>
                </Grid>
            </Border>

            <!-- ── Position label ─────────────────────────────────────── -->
            <Border Grid.Row="1"
                    x:Name="PositionBorder"
                    Background="#FFF0F0F0"
                    BorderBrush="#FFD0D0D0"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                <TextBlock x:Name="PositionLabel"
                           FontSize="8" FontFamily="Consolas"
                           Foreground="#FF666666"
                           Padding="6,2,6,2"/>
            </Border>

            <!-- ── Body ───────────────────────────────────────────────── -->
            <ContentPresenter Grid.Row="2"
                              Content="{Binding PanelBody,
                                  RelativeSource={RelativeSource AncestorType=ctl:DraggablePanel}}"/>

            <!-- ── Resize grip ─────────────────────────────────────────── -->
            <Thumb Grid.Row="2"
                   Width="14" Height="14"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Cursor="SizeNWSE"
                   DragDelta="ResizeGrip_DragDelta"
                   DragCompleted="ResizeGrip_DragCompleted"
                   Visibility="{Binding ShowResizeGrip,
                       RelativeSource={RelativeSource AncestorType=ctl:DraggablePanel},
                       Converter={StaticResource BoolToVisConverter}}">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Path Data="M 0 14 L 14 0 L 14 14 Z" Fill="#66888888"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

        </Grid>
    </Border>
</UserControl>
