<UserControl x:Class="MiniIDEv04.Controls.ProjectZipLauncherControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:MiniIDEv04.Controls"
             Cursor="SizeAll">

    <Border BorderBrush="#44000000" BorderThickness="1" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{Binding TitleBarBrush, RelativeSource={RelativeSource AncestorType=ctl:ProjectZipLauncherControl}}"
                    CornerRadius="4,4,0,0">
                <TextBlock Text="{Binding PanelTitle, RelativeSource={RelativeSource AncestorType=ctl:ProjectZipLauncherControl}}"
                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="8,0"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <!-- Position label (shown during drag) -->
            <Border Grid.Row="1" x:Name="PositionBorder"
                    Background="#FFF0F0F0" BorderBrush="#FFD0D0D0"
                    BorderThickness="0,0,0,1" Visibility="Collapsed">
                <TextBlock x:Name="PositionLabel" FontSize="8" FontFamily="Consolas"
                           Foreground="#FF666666" Padding="6,2,6,2"/>
            </Border>

            <!-- Body — zip icon on dark green, click to zip -->
            <Border Grid.Row="2" Background="#FF1B5E20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🗜"
                               FontSize="28"
                               HorizontalAlignment="Center"
                               ToolTip="Click to zip the project"/>
                    <TextBlock Text="ZIP"
                               FontSize="7"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               Foreground="#AAFFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>
