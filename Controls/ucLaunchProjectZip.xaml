<UserControl x:Class="CryptoCostBasesEFCore.ucControls.ucLaunchProjectZip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="50" Height="50"
             ToolTip="Click to open Project Zip tool">

    <UserControl.Resources>
        <Style x:Key="ZipLaunchBtnStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="50" Height="50">

                            <!-- Outer circle -->
                            <Ellipse x:Name="OuterCircle"
                                     Width="50" Height="50"
                                     Fill="#FF1565C0"
                                     Stroke="#FF0D47A1"
                                     StrokeThickness="1.5"/>

                            <!-- Inner circle -->
                            <Ellipse Width="34" Height="34"
                                     Fill="#FF0D1B26"
                                     Stroke="#FF263238"
                                     StrokeThickness="1"/>

                            <!-- Archive / zip box icon drawn in XAML -->
                            <Canvas Width="50" Height="50">

                                <!-- Box body -->
                                <Rectangle Canvas.Left="14" Canvas.Top="20"
                                           Width="22" Height="16"
                                           Fill="#FF4A9EFF" RadiusX="2" RadiusY="2"/>

                                <!-- Lid -->
                                <Rectangle Canvas.Left="12" Canvas.Top="16"
                                           Width="26" Height="6"
                                           Fill="#FF82B1FF" RadiusX="2" RadiusY="2"/>

                                <!-- Lid clasp -->
                                <Rectangle Canvas.Left="21" Canvas.Top="14"
                                           Width="8" Height="4"
                                           Fill="#FF1565C0" RadiusX="1" RadiusY="1"/>

                                <!-- Zip teeth stripe -->
                                <Rectangle Canvas.Left="23" Canvas.Top="20"
                                           Width="4" Height="2" Fill="White" Opacity="0.7"/>
                                <Rectangle Canvas.Left="23" Canvas.Top="24"
                                           Width="4" Height="2" Fill="White" Opacity="0.7"/>
                                <Rectangle Canvas.Left="23" Canvas.Top="28"
                                           Width="4" Height="2" Fill="White" Opacity="0.7"/>

                                <!-- Down-arrow (indicates compress/zip action) -->
                                <Path Canvas.Left="20" Canvas.Top="7"
                                      Data="M 5,0 L 5,5 L 0,5 L 5,9 L 10,5 L 5,5"
                                      Fill="#FFFFD54F"
                                      Stroke="#FFFFA000"
                                      StrokeThickness="0.5"/>

                                <!-- Label -->
                                <TextBlock Canvas.Left="13" Canvas.Top="37"
                                           Text="ZIP"
                                           FontSize="6"
                                           FontWeight="ExtraBold"
                                           FontFamily="Segoe UI"
                                           Foreground="#FFE0F7FA"
                                           TextAlignment="Center"
                                           Width="24"/>

                            </Canvas>

                            <!-- Hover / press triggers -->
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="OuterCircle" Property="Fill" Value="#FF1976D2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="OuterCircle" Property="Fill" Value="#FF0D47A1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Pulse ring animation behind the button -->
        <Ellipse x:Name="PulseRing"
                 Width="50" Height="50"
                 Stroke="#FF1565C0"
                 StrokeThickness="2"
                 Opacity="0"
                 IsHitTestVisible="False">
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="PulseRing"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0.7" To="0"
                                             Duration="0:0:2"
                                             AutoReverse="False"/>
                            <DoubleAnimationUsingKeyFrames
                                             Storyboard.TargetName="PulseRing"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:2" Value="1.5"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames
                                             Storyboard.TargetName="PulseRing"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:2" Value="1.5"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
            <Ellipse.RenderTransform>
                <ScaleTransform CenterX="25" CenterY="25"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- The actual clickable button -->
        <Button Style="{StaticResource ZipLaunchBtnStyle}"
                Click="LaunchButton_Click"/>
    </Grid>

</UserControl>
