<UserControl x:Class="MiniIDEv04.Controls.ToolboxLauncherControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:MiniIDEv04.Controls"
             Width="80" MinHeight="80"
             Cursor="SizeAll">

    <Border BorderBrush="#44000000"
            BorderThickness="1"
            CornerRadius="4"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ─────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{Binding TitleBarBrush,
                        RelativeSource={RelativeSource AncestorType=ctl:ToolboxLauncherControl}}"
                    CornerRadius="4,4,0,0">
                <TextBlock Text="🧰"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- ── Body ──────────────────────────────────────────────── -->
            <Grid Grid.Row="1">
                <TextBlock Text="Toolbox"
                           FontSize="9"
                           FontWeight="SemiBold"
                           Foreground="#FF555555"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="4"/>
            </Grid>

        </Grid>
    </Border>
</UserControl>
