<Window xmlns:CryptoCostBasesEFCore="clr-namespace:CryptoCostBasesEFCore" 
    xmlns:Views="clr-namespace:CryptoCostBasesEFCore.Views"
    x:Class="CryptoCostBasesEFCore.Views.ManualBatchEntryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:ucControls="CryptoCostBasesEFCore.ucControls"
    Title="Manual Batch Entry"
    Height="650"
    Width="1100"
    MinHeight="460"
    MinWidth="800"
    WindowStartupLocation="CenterOwner"
    Background="#FF1E1E1E"
    Foreground="White"
    ShowInTaskbar="True">

    <Window.Resources>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"      Value="28"/>
            <Setter Property="Padding"     Value="12,2"/>
            <Setter Property="Margin"      Value="0,0,6,0"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="11"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF888888"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- Exchange/Type ComboBox style -->
        <Style x:Key="GridCombo" TargetType="ComboBox">
            <Setter Property="Background"  Value="#FF2E7D32"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#FF1B5E20"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="IsEditable"  Value="True"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FF2E7D32"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding"    Value="6,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FF43A047"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small "+" button for new wallet -->
        <Style x:Key="NewWalletBtn" TargetType="Button">
            <Setter Property="Width"       Value="22"/>
            <Setter Property="Height"      Value="22"/>
            <Setter Property="Background"  Value="#FF1565C0"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="0"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="ToolTip"     Value="Create a new wallet"/>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF1A237E" CornerRadius="4" Padding="12,8">
            <DockPanel>
                <TextBlock Text="✏  Manual Batch Entry"
                           Foreground="White" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding RowCount}"
                           Foreground="#FFAAAAAA" FontSize="11"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- ── Quick-fill toolbar ─────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#FF252526" CornerRadius="4" Padding="10,7">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="Quick Fill —" VerticalAlignment="Center"
                           Foreground="#FF888888" FontSize="11" Margin="0,0,10,0"/>

                <TextBlock Text="Exchange:" VerticalAlignment="Center"
                           Foreground="#FFAAAAAA" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="QuickExchangeCombo"
                          Width="140" Height="24"
                          Style="{StaticResource GridCombo}"
                          Margin="0,0,10,0"
                          Text="{Binding SelectedExchange, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Select Exchange to show on all records added"/>

                <TextBlock Text="Type:" VerticalAlignment="Center"
                           Foreground="#FFAAAAAA" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="QuickTypeCombo"
                          Width="110" Height="24"
                          Style="{StaticResource GridCombo}"
                          Margin="0,0,10,0"
                          ToolTip="Pre-fill Type on new rows"/>

                <Button Content="➕  Add Row"
                        Style="{StaticResource ActionBtn}"
                        Width="90" Background="#FF2E7D32"
                        Click="AddRow_Click"
                        ToolTip="Add a new blank row"/>

                <Button Content="⧉  Duplicate Last"
                        Style="{StaticResource ActionBtn}"
                        Width="120" Background="#FF37474F"
                        Command="{Binding DuplicateRowCommand}"
                        ToolTip="Duplicate the last row (amounts cleared)"/>

                <Button Content="🗑  Clear All"
                        Style="{StaticResource ActionBtn}"
                        Width="90" Background="#FF5D4037"
                        Command="{Binding ClearAllCommand}"
                        ToolTip="Remove all rows"/>

            </StackPanel>
        </Border>

        <!-- ── Grid area ──────────────────────────────────────────────────── -->
        <Border Grid.Row="4" Background="#FF252526" CornerRadius="4" Padding="1">
            <StackPanel>

                <TextBlock x:Name="infoExchange" HorizontalAlignment="Left"
                           Height="30" Width="484"
                           Text="  Quick Fill Exchange = Not Set"
                           Foreground="Red" FontSize="14"/>

                <WrapPanel Height="50" Width="100" HorizontalAlignment="Left">
                    <Views:ucSendButton1/>
                </WrapPanel>

                <telerik:RadGridView
                    x:Name="BatchGrid"
                    ItemsSource="{Binding Rows}"
                    AutoGenerateColumns="False"
                    IsReadOnly="False"
                    EditTriggers="CellClick"
                    SelectionMode="Extended"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="True"
                    AlternateRowBackground="AliceBlue"
                    AlternationCount="2"
                    GridLinesVisibility="Both"
                    ShowGroupPanel="False"
                    FontSize="11"
                    CellEditEnded="BatchGrid_CellEditEnded"
                    PreparingCellForEdit="BatchGrid_PreparingCellForEdit"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <telerik:RadGridView.Columns>

                        <!-- Date -->
                        <telerik:GridViewDataColumn Header="Date (UTC)"
                            DataMemberBinding="{Binding DateUtc, StringFormat={}{0:yyyy-MM-dd}}"
                            Width="100" IsReadOnly="False"/>

                        <!-- Exchange -->
                        <telerik:GridViewComboBoxColumn Header="Exchange"
                            DataMemberBinding="{Binding TransExchange, Mode=TwoWay}"
                            Width="140" x:Name="ExchangeColumn"
                            IsComboBoxEditable="True"/>

                        <!-- Type -->
                        <telerik:GridViewComboBoxColumn Header="Type"
                            DataMemberBinding="{Binding Type, Mode=TwoWay}"
                            Width="110" x:Name="TypeColumn"
                            IsComboBoxEditable="True"/>

                        <!-- From Wallet combo -->
                        <telerik:GridViewComboBoxColumn Header="From Wallet"
                            DataMemberBinding="{Binding FromWallet, Mode=TwoWay}"
                            DisplayMemberPath="DisplayLabel"
                            SelectedValueMemberPath="WalletName"
                            Width="200" x:Name="FromWalletColumn"
                            IsComboBoxEditable="True"/>

                        <!-- From Wallet "+" button -->
                        <telerik:GridViewColumn Header="" Width="28" IsReadOnly="True">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+"
                                            Style="{StaticResource NewWalletBtn}"
                                            Tag="{Binding}"
                                            Click="NewFromWallet_Click"
                                            ToolTip="Create new From Wallet"/>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>

                        <!-- From Amount -->
                        <telerik:GridViewDataColumn Header="From Amount"
                            DataMemberBinding="{Binding FromAmount, Mode=TwoWay, StringFormat=N8}"
                            Width="110"/>

                        <!-- From Currency -->
                        <telerik:GridViewComboBoxColumn Header="From Currency"
                            DataMemberBinding="{Binding FromCurrency, Mode=TwoWay}"
                            Width="100" x:Name="FromCurrencyColumn"
                            IsComboBoxEditable="True"/>

                        <!-- From Currency "+" button -->
                        <telerik:GridViewColumn Header="" Width="28" IsReadOnly="True">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+"
                                            Style="{StaticResource NewWalletBtn}"
                                            Tag="{Binding}"
                                            Click="NewFromCurrency_Click"
                                            ToolTip="Add new From Currency symbol"/>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>

                        <!-- To Wallet combo -->
                        <telerik:GridViewComboBoxColumn Header="To Wallet"
                            DataMemberBinding="{Binding ToWallet, Mode=TwoWay}"
                            DisplayMemberPath="DisplayLabel"
                            SelectedValueMemberPath="WalletName"
                            Width="200" x:Name="ToWalletColumn"
                            IsComboBoxEditable="True"/>

                        <!-- To Wallet "+" button -->
                        <telerik:GridViewColumn Header="" Width="28" IsReadOnly="True">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+"
                                            Style="{StaticResource NewWalletBtn}"
                                            Tag="{Binding}"
                                            Click="NewToWallet_Click"
                                            ToolTip="Create new To Wallet"/>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>

                        <!-- To Amount -->
                        <telerik:GridViewDataColumn Header="To Amount"
                            DataMemberBinding="{Binding ToAmount, Mode=TwoWay, StringFormat=N8}"
                            Width="110"/>

                        <!-- To Currency -->
                        <telerik:GridViewComboBoxColumn Header="To Currency"
                            DataMemberBinding="{Binding ToCurrency, Mode=TwoWay}"
                            Width="100" x:Name="ToCurrencyColumn"
                            IsComboBoxEditable="True"/>

                        <!-- To Currency "+" button -->
                        <telerik:GridViewColumn Header="" Width="28" IsReadOnly="True">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+"
                                            Style="{StaticResource NewWalletBtn}"
                                            Tag="{Binding}"
                                            Click="NewToCurrency_Click"
                                            ToolTip="Add new To Currency symbol"/>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>

                        <!-- Fee Amount -->
                        <telerik:GridViewDataColumn Header="Fee Amount"
                            DataMemberBinding="{Binding FeeAmount, Mode=TwoWay, StringFormat=N8}"
                            Width="100"/>

                        <!-- Fee Currency -->
                        <telerik:GridViewComboBoxColumn Header="Fee Currency"
                            DataMemberBinding="{Binding FeeCurrency, Mode=TwoWay}"
                            Width="95" x:Name="FeeCurrencyColumn"
                            IsComboBoxEditable="True"/>

                        <!-- Net Value -->
                        <!-- Net Worth Amount -->
                        <telerik:GridViewDataColumn Header="NW Amount"
                            DataMemberBinding="{Binding NetWorthAmount, Mode=TwoWay, StringFormat=N8}"
                            Width="110"/>

                        <!-- Net Worth PPU — auto-calculated, user-editable -->
                        <telerik:GridViewDataColumn Header="NW PPU"
                            DataMemberBinding="{Binding NetWorthPPU, Mode=TwoWay, StringFormat=N6}"
                            Width="100"/>

                        <telerik:GridViewDataColumn Header="Net Value"
                            DataMemberBinding="{Binding NetValue, Mode=TwoWay, StringFormat=N8}"
                            Width="100"/>

                        <!-- Funds Source -->
                        <telerik:GridViewComboBoxColumn Header="Funds Source"
                            DataMemberBinding="{Binding FundsSource, Mode=TwoWay}"
                            Width="110" x:Name="FundsSourceColumn"
                            IsComboBoxEditable="True"/>

                        <!-- Description -->
                        <telerik:GridViewDataColumn Header="Description"
                            DataMemberBinding="{Binding Description, Mode=TwoWay}"
                            Width="*"/>

                        <!-- Delete -->
                        <telerik:GridViewColumn Header="" Width="36" IsReadOnly="True">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Width="24" Height="22"
                                        Background="#FF5D4037" Foreground="White"
                                        BorderBrush="Transparent" FontSize="10"
                                        FontWeight="SemiBold"
                                        Tag="{Binding}"
                                        Click="DeleteRow_Click"
                                        ToolTip="Remove this row"/>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </StackPanel>
        </Border>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="6" Background="#FF1A1A2E" CornerRadius="3" Padding="10,5">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#FFAAAAAA" FontSize="11"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ── Bottom action bar ──────────────────────────────────────────── -->
        <Border Grid.Row="8" Background="#FF252526" CornerRadius="4" Padding="10,8">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="✖  Close"
                        Width="90" Height="28"
                        Background="#FF5D4037" Foreground="White"
                        BorderBrush="Transparent" FontWeight="SemiBold" FontSize="11"
                        Margin="0"
                        Click="CloseButton_Click"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="📤  Send To Staging"
                            Width="150" Height="28"
                            Background="#FF2E7D32" Foreground="White"
                            BorderBrush="Transparent" FontWeight="Bold" FontSize="12"
                            Margin="0,0,8,0"
                            Command="{Binding SendToStagingCommand}"
                            ToolTip="Validate and push all rows to the Staging grid"/>

                    <TextBlock Text="{Binding RowCount}"
                               VerticalAlignment="Center"
                               Foreground="#FF888888" FontSize="11" Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
