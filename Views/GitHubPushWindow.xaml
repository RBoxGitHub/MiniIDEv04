<Window x:Class="MiniIDEv04.Views.GitHubPushWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        Title="🐙 GitHub Push"
        Width="560" Height="460"
        MinWidth="480" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF1B5E20" Padding="12,8">
            <TextBlock Text="🐙  GitHub — Commit and Push"
                       Foreground="White" FontSize="12"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Border>

        <!-- Tab control -->
        <TabControl Grid.Row="1" Margin="4,4,4,0"
                    SelectionChanged="TabControl_SelectionChanged">

            <!-- ── Push tab ── -->
            <TabItem Header="Push">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Commit input row -->
                    <Grid Grid.Row="0" Margin="8,8,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <telerik:RadWatermarkTextBox Grid.Column="0"
                            x:Name="CommitMessageBox"
                            WatermarkContent="Commit message..."
                            Background="#FFF0F8FF"
                            Margin="0,0,4,0"
                            telerik:StyleManager.Theme="Windows11"/>
                        <telerik:RadWatermarkTextBox Grid.Column="1"
                            x:Name="VersionTagBox"
                            WatermarkContent="v4.x.x"
                            Background="#FFF0F8FF"
                            Margin="0,0,4,0"
                            telerik:StyleManager.Theme="Windows11"/>
                        <telerik:RadButton Grid.Column="2"
                            Content="🐙 Commit + Push"
                            Style="{StaticResource AddButtonStyle}"
                            Click="CommitPush_Click"/>
                    </Grid>

                    <!-- Quick action row + log -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0"
                                   Orientation="Horizontal"
                                   Height="30"
                                   Background="#FFF5F5F5"
                                   Margin="8,0,8,0">
                            <telerik:RadButton Content="⬇ Pull"
                                Width="70" Height="22" Margin="0,4,4,4"
                                FontSize="10"
                                Click="Pull_Click"
                                ToolTip="git pull origin main"
                                telerik:StyleManager.Theme="Windows11"/>
                            <telerik:RadButton Content="🐙 Commit + Push"
                                Width="120" Height="22" Margin="0,4,4,4"
                                FontSize="10"
                                Style="{StaticResource AddButtonStyle}"
                                Click="Push_Click"
                                ToolTip="git add . + commit + push origin main"/>
                        </WrapPanel>

                        <!-- Output log + status -->
                        <Border Grid.Row="1" Margin="8,4,8,8"
                                BorderBrush="#FFD0D0D0" BorderThickness="1"
                                Background="#FF1E1E1E" CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0" x:Name="LogScroller"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="LogOutput"
                                               FontFamily="Consolas" FontSize="9"
                                               Foreground="#FF90EE90"
                                               Padding="6,4"
                                               TextWrapping="Wrap"/>
                                </ScrollViewer>

                                <!-- Push status message -->
                                <Border Grid.Row="1"
                                        x:Name="PushStatusBorder"
                                        Background="#FF0D2B0D"
                                        BorderBrush="#FF2E7D32"
                                        BorderThickness="0,1,0,0"
                                        Padding="8,6"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="PushStatusText"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="#FF69F0AE"
                                               TextAlignment="Center"
                                               Text="✅  Successfully committed and pushed to GitHub!"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Git Log tab ── -->
            <TabItem Header="Git Log">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView Grid.Row="0"
                              x:Name="GitLogList"
                              BorderBrush="#FFD0D0D0"
                              BorderThickness="1"
                              FontSize="11">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Date"    Width="130"
                                    DisplayMemberBinding="{Binding PushedAt, StringFormat='{}{0:MMM dd yyyy HH:mm}'}"/>
                                <GridViewColumn Header="Message" Width="220"
                                    DisplayMemberBinding="{Binding CommitMessage}"/>
                                <GridViewColumn Header="Tag"     Width="70"
                                    DisplayMemberBinding="{Binding VersionTag}"/>
                                <GridViewColumn Header="Status"  Width="60"
                                    DisplayMemberBinding="{Binding SuccessDisplay}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock Grid.Row="1"
                               x:Name="GitLogStatus"
                               FontSize="10"
                               Foreground="#FF777777"
                               Margin="0,4,0,0"
                               Text=""/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#FFF5F5F5"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <DockPanel>
                <telerik:RadButton DockPanel.Dock="Right"
                    Content="Close" Width="80"
                    telerik:StyleManager.Theme="Windows11"
                    Click="Close_Click"/>
                <TextBlock x:Name="StatusText"
                    VerticalAlignment="Center"
                    FontSize="11" Foreground="#FF555555"
                    Text="Enter a commit message and click Commit + Push"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
