<Window x:Class="MiniIDEv04.Views.DropZoneSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        Title="📦 Deploy Summary"
        Width="640" Height="560"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="White"
        telerik:StyleManager.Theme="Windows11">

    <Window.Resources>
        <Style x:Key="StatBoxStyle" TargetType="Border">
            <Setter Property="CornerRadius"   Value="4"/>
            <Setter Property="Padding"        Value="12,8"/>
            <Setter Property="Margin"         Value="4,0"/>
            <Setter Property="MinWidth"       Value="80"/>
        </Style>
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"       Value="22"/>
            <Setter Property="FontWeight"     Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground"     Value="White"/>
        </Style>
        <Style x:Key="StatCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize"       Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="Opacity"        Value="0.85"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF4A148C" Padding="16,10">
            <StackPanel>
                <TextBlock Text="📦  Deploy Summary"
                           Foreground="White" FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="ZipNameText"
                           Foreground="#FFCE93D8" FontSize="10"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Stat boxes ───────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#FFF3E5F5" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Border Style="{StaticResource StatBoxStyle}" Background="#FF4A148C">
                    <StackPanel>
                        <TextBlock x:Name="TotalCount"  Style="{StaticResource StatLabelStyle}"  Text="0"/>
                        <TextBlock                       Style="{StaticResource StatCaptionStyle}" Text="Total"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatBoxStyle}" Background="#FF2E7D32">
                    <StackPanel>
                        <TextBlock x:Name="NewCount"    Style="{StaticResource StatLabelStyle}"  Text="0"/>
                        <TextBlock                       Style="{StaticResource StatCaptionStyle}" Text="New"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatBoxStyle}" Background="#FF1565C0">
                    <StackPanel>
                        <TextBlock x:Name="UpdatedCount" Style="{StaticResource StatLabelStyle}"  Text="0"/>
                        <TextBlock                        Style="{StaticResource StatCaptionStyle}" Text="Updated"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatBoxStyle}" Background="#FF757575">
                    <StackPanel>
                        <TextBlock x:Name="SkippedCount" Style="{StaticResource StatLabelStyle}"  Text="0"/>
                        <TextBlock                        Style="{StaticResource StatCaptionStyle}" Text="Skipped"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatBoxStyle}" Background="#FFC62828">
                    <StackPanel>
                        <TextBlock x:Name="ErrorCount"   Style="{StaticResource StatLabelStyle}"  Text="0"/>
                        <TextBlock                        Style="{StaticResource StatCaptionStyle}" Text="Errors"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- ── Commit message ───────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#FFF9F9F9"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Commit:"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#FF555555"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox   Grid.Column="1"
                           x:Name="CommitMessageBox"
                           FontSize="10"
                           IsReadOnly="True"
                           Background="Transparent"
                           BorderThickness="0"
                           VerticalAlignment="Center"
                           TextWrapping="NoWrap"/>
                <Button    Grid.Column="2"
                           Content="📋 Copy"
                           FontSize="10"
                           Height="24" Padding="8,0"
                           Click="CopyCommit_Click"
                           Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── File list ────────────────────────────────────────────── -->
        <telerik:RadGridView Grid.Row="3"
                             x:Name="FileGrid"
                             Margin="8"
                             AutoGenerateColumns="False"
                             telerik:StyleManager.Theme="Windows11"
                             AlternateRowBackground="#FFF3E5F5"
                             AlternationCount="2"
                             IsReadOnly="True"
                             RowIndicatorVisibility="Collapsed"
                             SelectionMode="Single">
            <telerik:RadGridView.Columns>
                <telerik:GridViewDataColumn Header="Status"
                                            DataMemberBinding="{Binding StatusIcon}"
                                            Width="70"/>
                <telerik:GridViewDataColumn Header="File"
                                            DataMemberBinding="{Binding FileName}"
                                            Width="200"/>
                <telerik:GridViewDataColumn Header="Destination"
                                            DataMemberBinding="{Binding Destination}"
                                            Width="*"/>
            </telerik:RadGridView.Columns>
        </telerik:RadGridView>

        <!-- ── Build status ─────────────────────────────────────────── -->
        <Border Grid.Row="4"
                x:Name="BuildStatusBorder"
                Background="#FFF1F8E9"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,1,0,0"
                Padding="12,6"
                Visibility="Collapsed">
            <TextBlock x:Name="BuildStatusText"
                       FontSize="11"
                       Foreground="#FF33691E"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- ── Footer ───────────────────────────────────────────────── -->
        <Border Grid.Row="5"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,1,0,0"
                Background="White"
                Padding="12,8">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Close"
                        Width="80" Height="28"
                        Click="Close_Click"
                        Margin="8,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        x:Name="BuildButton"
                        Content="🔨 Build Now"
                        Height="28" Padding="12,0"
                        Background="#FF4A148C"
                        Foreground="White"
                        BorderThickness="0"
                        Click="BuildButton_Click"/>
                <TextBlock x:Name="FooterText"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="#FF888888"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
