<Window x:Class="MiniIDEv04.Views.ToolboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        Title="🧰 Toolbox"
        Height="680" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="White">

    <Window.Resources>
        <DataTemplate x:Key="ToolboxEntryTemplate">
            <Border Padding="4,3" Background="Transparent" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE8F4FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Label}"
                           FontSize="11" Foreground="#FF222222"
                           ToolTip="{Binding Tooltip}"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </DataTemplate>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Watcher status bar -->
            <RowDefinition Height="Auto"/>   <!-- Search -->
            <RowDefinition Height="*"/>      <!-- RadPanelBar -->
            <RowDefinition Height="Auto"/>   <!-- Scan progress -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF006064" Padding="12,8">
            <Grid>
                <TextBlock Text="🧰  Toolbox"
                           Foreground="White" FontSize="14"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ScanDllButton"
                            Content="🔌 Scan DLL"
                            Height="24" Padding="8,0" FontSize="10"
                            Background="#FF00796B" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Margin="0,0,6,0"
                            Click="ScanDllButton_Click"/>
                    <Button x:Name="ScanButton"
                            Content="🔍 Scan Libraries"
                            Height="24" Padding="8,0" FontSize="10"
                            Background="#FF004D40" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="ScanButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Watcher status bar ───────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#FFE0F2F1"
                BorderBrush="#FF80CBC4"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="WatcherStatusText"
                           FontSize="9" Foreground="#FF00695C"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Ellipse Grid.Column="1"
                         x:Name="WatcherIndicator"
                         Width="8" Height="8"
                         Margin="6,0,0,0"
                         Fill="#FF4CAF50"
                         VerticalAlignment="Center"
                         ToolTip="DLL watcher active"/>
            </Grid>
        </Border>

        <!-- ── Search ──────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Margin="8,8,8,4"
                BorderBrush="#FFB0B0B0"
                BorderThickness="1" CornerRadius="3">
            <Grid Background="White">
                <TextBlock x:Name="Watermark"
                           Text="Search controls..."
                           Foreground="#FFAAAAAA" FontSize="11"
                           Margin="6,0" VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
                <TextBox x:Name="SearchBox"
                         BorderThickness="0" Background="Transparent"
                         Height="26" Padding="4,0" FontSize="11"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
            </Grid>
        </Border>

        <!-- ── RadPanelBar ──────────────────────────────────────────── -->
        <telerik:RadPanelBar
            Grid.Row="3"
            x:Name="ToolboxPanelBar"
            Margin="4,0,4,4"
            telerik:StyleManager.Theme="Windows11">
            <telerik:RadPanelBar.ItemTemplate>
                <HierarchicalDataTemplate
                    ItemsSource="{Binding Entries}"
                    ItemTemplate="{StaticResource ToolboxEntryTemplate}">
                    <TextBlock Text="{Binding Header}"
                               FontSize="11" FontWeight="SemiBold"/>
                </HierarchicalDataTemplate>
            </telerik:RadPanelBar.ItemTemplate>
        </telerik:RadPanelBar>

        <!-- ── Scan progress ────────────────────────────────────────── -->
        <Border Grid.Row="4"
                Background="#FFF5F5F5"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,1,0,0"
                Padding="8,6"
                x:Name="ScanProgressPanel"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="ScanStatusText"
                           FontSize="10" Foreground="#FF444444"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                <ProgressBar x:Name="ScanProgressBar"
                             Height="6" Minimum="0" Maximum="100" Value="0"
                             Foreground="#FF006064"/>
            </StackPanel>
        </Border>

        <!-- ── Footer ──────────────────────────────────────────────── -->
        <Border Grid.Row="5"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,1,0,0"
                Background="White"
                Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Save log checkbox -->
                <CheckBox Grid.Row="0"
                          x:Name="SaveScanLogCheckBox"
                          Content="💾 Save scan log to watch folder"
                          FontSize="9" Foreground="#FF666666"
                          Margin="0,0,0,4"
                          IsChecked="True"
                          Checked="SaveScanLog_Changed"
                          Unchecked="SaveScanLog_Changed"
                          ToolTip="Save a .log file to the scan folder after each DLL scan"/>

                <!-- Footer status + close -->
                <Grid Grid.Row="1">
                    <TextBlock x:Name="FooterText"
                               Foreground="#FF999999" FontSize="9"
                               VerticalAlignment="Center"/>
                    <Button Content="Close"
                            HorizontalAlignment="Right"
                            Width="70" Height="26"
                            Click="Close_Click"/>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>
