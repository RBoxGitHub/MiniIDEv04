<Window x:Class="MiniIDEv04.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        xmlns:vm="clr-namespace:MiniIDEv04.ViewModels"
        Title="{Binding AppVersion, StringFormat='MiniIDE — {0}'}"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.DataContext>
        <vm:ProjectViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Menu ══════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project"  Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="_Open Project" Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Project">
                <MenuItem Header="Add _Window"/>
                <MenuItem Header="Add _UserControl"/>
                <Separator/>
                <MenuItem Header="_Export to .sln" Command="{Binding ExportSlnCommand}"/>
            </MenuItem>
            <MenuItem Header="_Panels">
                <MenuItem Header="📝 Things To Do"
                          Command="{Binding TogglePanelAsyncCommand}"
                          CommandParameter="ThingsToDoPanel"/>
                <MenuItem Header="⚙ System Manager"
                          Command="{Binding TogglePanelAsyncCommand}"
                          CommandParameter="SysManagerPanel"/>
            </MenuItem>
        </Menu>

        <!-- ═══ Toolbar ═══════════════════════════════════════════════════ -->
        <telerik:RadToolBar Grid.Row="1">
            <telerik:RadButton Content="New"         Command="{Binding NewProjectCommand}"/>
            <telerik:RadButton Content="Open"        Command="{Binding OpenProjectCommand}"/>
            <telerik:RadButton Content="Save"        Command="{Binding SaveProjectCommand}"/>
            <telerik:RadToolBarSeparator/>
            <telerik:RadButton Content="▶ Preview"   Command="{Binding RunPreviewCommand}"/>
            <telerik:RadToolBarSeparator/>
            <telerik:RadButton Content="Export .sln" Command="{Binding ExportSlnCommand}"/>
        </telerik:RadToolBar>

        <!-- ═══ Docking + floating overlay ════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- ── RadDocking shell ──────────────────────────────────── -->
            <telerik:RadDocking telerik:StyleManager.Theme="Windows11">

                <!-- LEFT: Project Explorer + Toolbox -->
                <telerik:RadSplitContainer InitialPosition="DockedLeft" Width="240">
                    <telerik:RadPaneGroup>
                        <telerik:RadPane Header="Project Explorer">
                            <telerik:RadTreeView telerik:StyleManager.Theme="Windows11"/>
                        </telerik:RadPane>
                        <telerik:RadPane Header="Toolbox">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <telerik:RadWatermarkTextBox Grid.Row="0"
                                    WatermarkContent="Search controls..."
                                    Margin="4"/>
                                <telerik:RadPanelBar Grid.Row="1"
                                    ItemsSource="{Binding ToolboxGroups}"
                                    telerik:StyleManager.Theme="Windows11"/>
                            </Grid>
                        </telerik:RadPane>
                    </telerik:RadPaneGroup>
                </telerik:RadSplitContainer>

                <!-- CENTER: Editors -->
                <telerik:RadSplitContainer>
                    <telerik:RadPaneGroup x:Name="DocumentHost">
                        <telerik:RadPane Header="XAML">
                            <telerik:RadSyntaxEditor x:Name="XamlEditor"
                                telerik:StyleManager.Theme="Windows11"/>
                        </telerik:RadPane>
                        <telerik:RadPane Header="C# Code-Behind">
                            <telerik:RadSyntaxEditor x:Name="CodeEditor"
                                telerik:StyleManager.Theme="Windows11"/>
                        </telerik:RadPane>
                    </telerik:RadPaneGroup>
                </telerik:RadSplitContainer>

                <!-- RIGHT: Preview + Properties -->
                <telerik:RadSplitContainer InitialPosition="DockedRight" Width="320">
                    <telerik:RadPaneGroup>
                        <telerik:RadPane Header="Preview">
                            <Border BorderBrush="#22000000" BorderThickness="1"
                                    Background="White" Margin="4">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <ContentPresenter x:Name="PreviewHost"/>
                                </ScrollViewer>
                            </Border>
                        </telerik:RadPane>
                        <telerik:RadPane Header="Properties">
                            <telerik:RadPropertyGrid x:Name="PropertyGrid"
                                telerik:StyleManager.Theme="Windows11"/>
                        </telerik:RadPane>
                    </telerik:RadPaneGroup>
                </telerik:RadSplitContainer>

                <!-- BOTTOM docked pane removed — quick-add is now a DraggablePanel -->

            </telerik:RadDocking>

            <!-- ── Floating panel canvas overlay ─────────────────────── -->
            <!-- Canvas is intentionally empty at design time.           -->
            <!-- PanelControlFactory spawns all panels at runtime        -->
            <!-- from sys_Panels rows via SpawnPanelsFromDb().           -->
            <Canvas x:Name="FloatingCanvas"
                    Panel.ZIndex="100"
                    IsHitTestVisible="True"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
        </Grid>

        <!-- ═══ Status bar ════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding AppVersion}"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
