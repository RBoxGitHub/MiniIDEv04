<Window x:Class="MiniIDEv04.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        xmlns:vm="clr-namespace:MiniIDEv04.ViewModels"
        xmlns:ctl="clr-namespace:MiniIDEv04.Controls"
        Title="{Binding AppVersion, StringFormat='MiniIDE — {0}'}"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.DataContext>
        <vm:ProjectViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Menu ══════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project"  Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="_Open Project" Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Project">
                <MenuItem Header="Add _Window"/>
                <MenuItem Header="Add _UserControl"/>
                <Separator/>
                <MenuItem Header="_Export to .sln" Command="{Binding ExportSlnCommand}"/>
            </MenuItem>
            <MenuItem Header="_Panels">
                <MenuItem Header="📝 Things To Do"
                          Command="{Binding TogglePanelAsyncCommand}"
                          CommandParameter="ThingsToDoPanel"/>
                <MenuItem Header="⚙ System Manager"
                          Command="{Binding TogglePanelAsyncCommand}"
                          CommandParameter="SysManagerPanel"/>
            </MenuItem>
        </Menu>

        <!-- ═══ Toolbar ═══════════════════════════════════════════════════ -->
        <telerik:RadToolBar Grid.Row="1">
            <telerik:RadButton Content="New"         Command="{Binding NewProjectCommand}"/>
            <telerik:RadButton Content="Open"        Command="{Binding OpenProjectCommand}"/>
            <telerik:RadButton Content="Save"        Command="{Binding SaveProjectCommand}"/>
            <telerik:RadToolBarSeparator/>
            <telerik:RadButton Content="▶ Preview"   Command="{Binding RunPreviewCommand}"/>
            <telerik:RadToolBarSeparator/>
            <telerik:RadButton Content="Export .sln" Command="{Binding ExportSlnCommand}"/>
        </telerik:RadToolBar>

        <!-- ═══ Docking + floating overlay ════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- ── RadDocking shell ──────────────────────────────────── -->
            <telerik:RadDocking telerik:StyleManager.Theme="Windows11">

                <!-- LEFT: Project Explorer + Toolbox -->
                <telerik:RadSplitContainer InitialPosition="DockedLeft" Width="240">
                    <telerik:RadPaneGroup>
                        <telerik:RadPane Header="Project Explorer">
                            <telerik:RadTreeView telerik:StyleManager.Theme="Windows11"/>
                        </telerik:RadPane>
                        <telerik:RadPane Header="Toolbox">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <telerik:RadWatermarkTextBox Grid.Row="0"
                                    WatermarkContent="Search controls..."
                                    Margin="4"/>
                                <telerik:RadPanelBar Grid.Row="1"
                                    ItemsSource="{Binding ToolboxGroups}"
                                    telerik:StyleManager.Theme="Windows11"/>
                            </Grid>
                        </telerik:RadPane>
                    </telerik:RadPaneGroup>
                </telerik:RadSplitContainer>

                <!-- CENTER: Editors -->
                <telerik:RadSplitContainer>
                    <telerik:RadPaneGroup x:Name="DocumentHost">
                        <telerik:RadPane Header="XAML">
                            <telerik:RadSyntaxEditor x:Name="XamlEditor"
                                telerik:StyleManager.Theme="Windows11"/>
                        </telerik:RadPane>
                        <telerik:RadPane Header="C# Code-Behind">
                            <telerik:RadSyntaxEditor x:Name="CodeEditor"
                                telerik:StyleManager.Theme="Windows11"/>
                        </telerik:RadPane>
                    </telerik:RadPaneGroup>
                </telerik:RadSplitContainer>

                <!-- RIGHT: Preview + Properties -->
                <telerik:RadSplitContainer InitialPosition="DockedRight" Width="320">
                    <telerik:RadPaneGroup>
                        <telerik:RadPane Header="Preview">
                            <Border BorderBrush="#22000000" BorderThickness="1"
                                    Background="White" Margin="4">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <ContentPresenter x:Name="PreviewHost"/>
                                </ScrollViewer>
                            </Border>
                        </telerik:RadPane>
                        <telerik:RadPane Header="Properties">
                            <telerik:RadPropertyGrid x:Name="PropertyGrid"
                                telerik:StyleManager.Theme="Windows11"/>
                        </telerik:RadPane>
                    </telerik:RadPaneGroup>
                </telerik:RadSplitContainer>

                <!-- BOTTOM docked pane removed — quick-add is now a DraggablePanel -->

            </telerik:RadDocking>

            <!-- ── Floating panel canvas overlay ─────────────────────── -->
            <!-- Canvas has no background so RadDocking behind it stays   -->
            <!-- interactive. Each panel is hit-testable independently.   -->
            <Canvas x:Name="FloatingCanvas"
                    Panel.ZIndex="100"
                    IsHitTestVisible="True"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <!-- 📝 Quick Add Note — dedicated UserControl, full DataContext -->
                <ctl:QuickAddPanelControl x:Name="QuickAddPanel"
                    PanelKey="QuickAddPanel"
                    Width="620"
                    MinHeight="56"
                    IsHitTestVisible="True"
                    Canvas.Left="20" Canvas.Top="0"
                    PositionChanged="Panel_PositionChanged"
                    DraggingPosition="Panel_DraggingPosition"/>

                <!-- ⚙ Sys Manager — bottom-left, original position, text button -->
                <!-- Double-click opens SysManagerWindow modal                   -->
                <ctl:DraggablePanel x:Name="SysManagerPanel"
                    PanelKey="SysManagerPanel"
                    PanelTitle="⚙ Sys"
                    Width="120"
                    MinHeight="80"
                    ShowCloseButton="False"
                    ShowResizeGrip="False"
                    IsHitTestVisible="True"
                    Canvas.Left="20" Canvas.Top="700"
                    PositionChanged="Panel_PositionChanged"
                    DraggingPosition="Panel_DraggingPosition"
                    PanelDoubleClicked="Panel_DoubleClicked">
                    <ctl:DraggablePanel.TitleBarBrush>
                        <SolidColorBrush Color="#FF1A237E"/>
                    </ctl:DraggablePanel.TitleBarBrush>
                    <ctl:DraggablePanel.PanelBody>
                        <Border Background="#FF1A237E">
                            <TextBlock Text="⚙ Manage&#x0a;sys_ Tables"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"/>
                        </Border>
                    </ctl:DraggablePanel.PanelBody>
                </ctl:DraggablePanel>

                <!-- 📝 Notes launcher — freely floating, wrench icon drawn  -->
                <!-- as WPF Path geometry (no external image file needed)     -->
                <!-- Double-click opens ThingsToDoWindow modal                -->
                <ctl:DraggablePanel x:Name="SysManagerLauncher"
                    PanelKey="SysManagerLauncher"
                    PanelTitle="📝 Notes"
                    Width="80"
                    MinHeight="80"
                    ShowCloseButton="False"
                    ShowResizeGrip="False"
                    IsHitTestVisible="True"
                    Canvas.Left="20" Canvas.Top="0"
                    PositionChanged="Panel_PositionChanged"
                    DraggingPosition="Panel_DraggingPosition"
                    PanelDoubleClicked="Panel_DoubleClicked">
                    <ctl:DraggablePanel.TitleBarBrush>
                        <SolidColorBrush Color="#FF37474F"/>
                    </ctl:DraggablePanel.TitleBarBrush>
                    <ctl:DraggablePanel.PanelBody>
                        <Border Background="#FF263238">
                            <Viewbox Width="38" Height="38"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Stretch="Uniform">
                                <Path Fill="White"
                                      Data="M 28 4 C 22 4 17 8 16 14 L 2 28 C 0 30 0 33 2 35 L 5 38 C 7 40 10 40 12 38 L 26 24 C 32 23 36 18 36 12 C 36 10 35 8 34 6 L 28 12 L 24 8 Z M 6 33 C 6 34 5 35 4 35 C 3 35 2 34 2 33 C 2 32 3 31 4 31 C 5 31 6 32 6 33 Z"/>
                            </Viewbox>
                        </Border>
                    </ctl:DraggablePanel.PanelBody>
                </ctl:DraggablePanel>

            </Canvas>
        </Grid>

        <!-- ═══ Status bar ════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding AppVersion}"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
