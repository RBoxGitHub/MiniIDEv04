<Window x:Class="MiniIDEv04.Views.DropZoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        Title="📦 Drop Zone — File Deployer"
        Width="920" Height="580"
        MinWidth="700" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Body split -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF4A148C" Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="📦  Drop Zone — Claude File Deployer"
                           Foreground="White" FontSize="12"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="FileCountText"
                           DockPanel.Dock="Right"
                           Foreground="#FFCE93D8" FontSize="11"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Zip folder browser -->
            <Border Grid.Column="0"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="0,0,1,0"
                    Background="#FFF9F9F9">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Folder header -->
                    <Border Grid.Row="0" Background="#FF6A1B9A" Padding="8,6">
                        <TextBlock Text="📂 Zip Work Folder"
                                   Foreground="White" FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <!-- Folder path -->
                    <TextBox Grid.Row="1"
                             x:Name="ZipFolderBox"
                             IsReadOnly="True"
                             FontSize="8"
                             Background="#FFF0E8FF"
                             BorderThickness="0,0,0,1"
                             Padding="6,3"
                             TextWrapping="Wrap"/>

                    <!-- Zip file list -->
                    <ListBox Grid.Row="2"
                             x:Name="ZipFileList"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0"
                             SelectionChanged="ZipFileList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,2">
                                    <TextBlock Text="📦 " FontSize="11"/>
                                    <TextBlock Text="{Binding}" FontSize="10"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="160"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Refresh + Browse folder -->
                    <WrapPanel Grid.Row="3" Margin="4,4,4,4">
                        <telerik:RadButton Content="🔄"
                            Width="30" Height="24" Margin="0,0,4,0"
                            ToolTip="Refresh zip list"
                            Click="RefreshZipList_Click"
                            telerik:StyleManager.Theme="Windows11"/>
                        <telerik:RadButton Content="📂 Folder"
                            Height="24" Margin="0"
                            ToolTip="Change zip work folder"
                            Click="BrowseZipFolder_Click"
                            telerik:StyleManager.Theme="Windows11"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#FFE0E0E0"/>

            <!-- RIGHT: Zip controls + results -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Zip file row -->
                    <RowDefinition Height="Auto"/>  <!-- Project root row -->
                    <RowDefinition Height="*"/>     <!-- Results grid -->
                </Grid.RowDefinitions>

                <!-- Zip file row -->
                <Grid Grid.Row="0" Margin="8,8,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Zip File:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="10"/>
                    <TextBox Grid.Column="1"
                             x:Name="ZipPathBox"
                             IsReadOnly="True"
                             Background="#FFF0F8FF"
                             Padding="4,2"
                             VerticalAlignment="Center"
                             Margin="0,0,4,0"/>
                    <telerik:RadButton Grid.Column="2"
                        Content="📂 Browse..."
                        Margin="0,0,4,0"
                        Click="BrowseZip_Click"
                        telerik:StyleManager.Theme="Windows11"/>
                    <telerik:RadButton Grid.Column="3"
                        Content="⚙ Process Zip"
                        Style="{StaticResource AddButtonStyle}"
                        Click="ProcessZip_Click"
                        ToolTip="Read manifest and deploy files to project"/>
                </Grid>

                <!-- Project root row -->
                <Grid Grid.Row="1" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Project Root:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="10"/>
                    <TextBox Grid.Column="1"
                             x:Name="ProjectRootBox"
                             Background="#FFFFF9E6"
                             Padding="4,2"
                             VerticalAlignment="Center"
                             Margin="0,0,4,0"/>
                    <telerik:RadButton Grid.Column="2"
                        Content="📂 Browse..."
                        Click="BrowseRoot_Click"
                        telerik:StyleManager.Theme="Windows11"/>
                </Grid>

                <!-- Results grid -->
                <telerik:RadGridView Grid.Row="2"
                    x:Name="ResultsGrid"
                    Margin="8,0,8,8"
                    AutoGenerateColumns="False"
                    telerik:StyleManager.Theme="Windows11"
                    AlternateRowBackground="#FFE8F4FD"
                    AlternationCount="2"
                    IsReadOnly="True"
                    RowIndicatorVisibility="Collapsed"
                    SelectionMode="Single">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn
                            DataMemberBinding="{Binding Status}"
                            Header="Status" Width="80"/>
                        <telerik:GridViewDataColumn
                            DataMemberBinding="{Binding FileName}"
                            Header="File" Width="200"/>
                        <telerik:GridViewDataColumn
                            DataMemberBinding="{Binding Destination}"
                            Header="Destination" Width="160"/>
                        <telerik:GridViewDataColumn
                            DataMemberBinding="{Binding FullDestPath}"
                            Header="Full Path" Width="*"/>
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#FFF5F5F5"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <DockPanel>
                <telerik:RadButton DockPanel.Dock="Right"
                    Content="Close" Width="80"
                    telerik:StyleManager.Theme="Windows11"
                    Click="Close_Click"/>
                <telerik:RadButton DockPanel.Dock="Right"
                    Content="🗑 Clear Log" Width="90"
                    Margin="0,0,8,0"
                    telerik:StyleManager.Theme="Windows11"
                    Click="ClearLog_Click"/>
                <TextBlock x:Name="StatusText"
                    VerticalAlignment="Center" FontSize="11"
                    Foreground="#FF555555"
                    Text="Select a zip from the folder browser or browse manually"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
