<Window x:Class="MiniIDEv04.Views.SysManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        Title="⚙ System Table Manager"
        Width="1050" Height="580"
        MinWidth="700" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               telerik:StyleManager.Theme="Windows11">

            <!-- ══════════════════════════════════════════════════════════════
                 TAB 1 — sys_Panels
            ══════════════════════════════════════════════════════════════════ -->
            <telerik:RadTabItem Header="🗂 sys_Panels">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#FF1A237E" Padding="12,8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       Text="⚙  sys_Panels — live panel registry"
                                       Foreground="White" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PanelCountText"
                                       DockPanel.Dock="Right"
                                       Foreground="#FF90CAF9" FontSize="11"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>

                    <!-- Grid -->
                    <telerik:RadGridView Grid.Row="1"
                        x:Name="PanelsGrid"
                        Margin="8,8,8,0"
                        AutoGenerateColumns="False"
                        telerik:StyleManager.Theme="Windows11"
                        AlternateRowBackground="#FFE8F4FD"
                        AlternationCount="2"
                        GroupRowStyle="{StaticResource BlueGroupRowStyle}"
                        CanUserFreezeColumns="False"
                        IsReadOnly="False"
                        RowIndicatorVisibility="Collapsed"
                        SelectionMode="Single"
                        SelectionChanged="PanelsGrid_SelectionChanged">
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding PanelKey}"
                                Header="Panel Key" Width="160" IsReadOnly="True"/>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding PanelName}"
                                Header="Name" Width="160"/>
                            <telerik:GridViewCheckBoxColumn
                                DataMemberBinding="{Binding IsVisible}"
                                Header="Visible" Width="58"/>
                            <telerik:GridViewCheckBoxColumn
                                DataMemberBinding="{Binding IsPinned}"
                                Header="Pinned" Width="58"/>
                            <telerik:GridViewCheckBoxColumn
                                DataMemberBinding="{Binding HasSaveButton}"
                                Header="Save Btn" Width="68"/>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding PosLeft}"
                                Header="Left" Width="58"/>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding PosTop}"
                                Header="Top" Width="58"/>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding PanelWidth}"
                                Header="W" Width="58"/>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding PanelHeight}"
                                Header="H" Width="58"/>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding TitleBarColor}"
                                Header="Title Color" Width="100"/>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding LaunchTarget}"
                                Header="Launch Target" Width="140"/>
                            <telerik:GridViewDataColumn
                                DataMemberBinding="{Binding Description}"
                                Header="Description" Width="*"/>
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>

                    <!-- Action buttons -->
                    <WrapPanel Grid.Row="2" Margin="8,8,8,4" Orientation="Horizontal">
                        <telerik:RadButton Content="💾 Save Changes"
                            x:Name="SaveChangesButton"
                            Style="{StaticResource AddButtonStyle}"
                            Margin="0,0,8,0"
                            Click="SaveChanges_Click"
                            ToolTip="Write all edited rows back to sys_Panels"/>
                        <telerik:RadButton Content="+ New Panel"
                            Margin="0,0,8,0"
                            Click="NewPanel_Click"/>
                        <telerik:RadButton Content="📋 Clone Selected"
                            Margin="0,0,8,0"
                            Click="ClonePanel_Click"/>
                        <telerik:RadButton Content="🔄 Refresh"
                            Margin="0,0,8,0"
                            Click="Refresh_Click"/>
                        <TextBlock x:Name="ActionStatusText"
                                   VerticalAlignment="Center"
                                   FontSize="11" Foreground="#FF555555"/>
                    </WrapPanel>
                </Grid>
            </telerik:RadTabItem>

            <!-- ══════════════════════════════════════════════════════════════
                 TAB 2 — sys_Controls
            ══════════════════════════════════════════════════════════════════ -->
            <telerik:RadTabItem Header="🧩 sys_Controls">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Header -->
                        <RowDefinition Height="*"/>      <!-- Master/detail split -->
                        <RowDefinition Height="Auto"/>   <!-- Action buttons -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#FF0D47A1" Padding="12,8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       Text="🧩  sys_Controls — control instance registry"
                                       Foreground="White" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ControlCountText"
                                       DockPanel.Dock="Right"
                                       Foreground="#FF90CAF9" FontSize="11"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>

                    <!-- Master / Detail split -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left — control instances grid -->
                        <telerik:RadGridView Grid.Column="0"
                            x:Name="ControlsGrid"
                            Margin="8,8,0,0"
                            AutoGenerateColumns="False"
                            telerik:StyleManager.Theme="Windows11"
                            AlternateRowBackground="#FFE8F4FD"
                            AlternationCount="2"
                            GroupRowStyle="{StaticResource BlueGroupRowStyle}"
                            CanUserFreezeColumns="False"
                            IsReadOnly="False"
                            RowIndicatorVisibility="Collapsed"
                            SelectionMode="Single"
                            SelectionChanged="ControlsGrid_SelectionChanged">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn
                                    DataMemberBinding="{Binding ControlKey}"
                                    Header="Key" Width="160" IsReadOnly="True"/>
                                <telerik:GridViewDataColumn
                                    DataMemberBinding="{Binding ControlName}"
                                    Header="Name" Width="130"/>
                                <telerik:GridViewDataColumn
                                    DataMemberBinding="{Binding ControlType}"
                                    Header="Type" Width="*"/>
                                <telerik:GridViewDataColumn
                                    DataMemberBinding="{Binding ParentKey}"
                                    Header="Parent" Width="130"/>
                                <telerik:GridViewCheckBoxColumn
                                    DataMemberBinding="{Binding IsVisible}"
                                    Header="Visible" Width="56"/>
                                <telerik:GridViewDataColumn
                                    DataMemberBinding="{Binding AssemblySource}"
                                    Header="Source" Width="70"/>
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1"
                                      Width="5"
                                      HorizontalAlignment="Stretch"
                                      Background="#FFE0E0E0"/>

                        <!-- Right — property picker panel -->
                        <Border Grid.Column="2"
                                Margin="0,8,8,0"
                                BorderBrush="#FFE0E0E0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Property panel header -->
                                <Border Grid.Row="0"
                                        Background="#FF37474F"
                                        Padding="8,6"
                                        CornerRadius="4,4,0,0">
                                    <TextBlock x:Name="PropPanelTitle"
                                               Text="Select a control to edit properties"
                                               Foreground="White"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </Border>

                                <!-- Control type picker -->
                                <Grid Grid.Row="1" Margin="8,8,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Type:"
                                               VerticalAlignment="Center"
                                               FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,6,0"/>
                                    <telerik:RadComboBox Grid.Column="1"
                                        x:Name="ControlTypePicker"
                                        DisplayMemberPath="ShortName"
                                        SelectionChanged="ControlTypePicker_SelectionChanged"
                                        telerik:StyleManager.Theme="Windows11"/>
                                </Grid>

                                <!-- Property picker -->
                                <Grid Grid.Row="2" Margin="8,0,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Property:"
                                               VerticalAlignment="Center"
                                               FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,6,0"/>
                                    <telerik:RadComboBox Grid.Column="1"
                                        x:Name="PropertyPicker"
                                        DisplayMemberPath="PropertyName"
                                        SelectionChanged="PropertyPicker_SelectionChanged"
                                        telerik:StyleManager.Theme="Windows11"/>
                                </Grid>

                                <!-- Property value input + add -->
                                <Grid Grid.Row="3" Margin="8,0,8,4" VerticalAlignment="Top">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <telerik:RadWatermarkTextBox Grid.Row="0"
                                        x:Name="PropertyValueBox"
                                        WatermarkContent="Enter value..."
                                        Background="#FFF0F8FF"
                                        Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1"
                                               x:Name="PropertyHintText"
                                               FontSize="9"
                                               Foreground="#FF888888"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6"/>

                                    <telerik:RadButton Grid.Row="2"
                                        Content="+ Add Property"
                                        Style="{StaticResource AddButtonStyle}"
                                        Click="AddProperty_Click"
                                        HorizontalAlignment="Left"/>
                                </Grid>

                                <!-- Existing properties for selected control -->
                                <telerik:RadGridView Grid.Row="4"
                                    x:Name="PropertiesGrid"
                                    Margin="8,4,8,8"
                                    AutoGenerateColumns="False"
                                    telerik:StyleManager.Theme="Windows11"
                                    AlternateRowBackground="#FFE8F4FD"
                                    AlternationCount="2"
                                    IsReadOnly="False"
                                    RowIndicatorVisibility="Collapsed">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn
                                            DataMemberBinding="{Binding PropertyName}"
                                            Header="Property" Width="120" IsReadOnly="True"/>
                                        <telerik:GridViewDataColumn
                                            DataMemberBinding="{Binding PropertyValue}"
                                            Header="Value" Width="*"/>
                                        <telerik:GridViewDataColumn
                                            DataMemberBinding="{Binding Category}"
                                            Header="Cat" Width="60" IsReadOnly="True"/>
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>

                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Action buttons -->
                    <WrapPanel Grid.Row="2" Margin="8,8,8,4" Orientation="Horizontal">
                        <telerik:RadButton Content="+ New Control"
                            Style="{StaticResource AddButtonStyle}"
                            Margin="0,0,8,0"
                            Click="NewControl_Click"
                            ToolTip="Add a new control instance row"/>
                        <telerik:RadButton Content="📋 Clone Control"
                            Margin="0,0,8,0"
                            Click="CloneControl_Click"/>
                        <telerik:RadButton Content="💾 Save Control"
                            Margin="0,0,8,0"
                            Click="SaveControl_Click"
                            ToolTip="Save selected control + its properties to DB"/>
                        <telerik:RadButton Content="🗑 Delete Control"
                            Margin="0,0,8,0"
                            Click="DeleteControl_Click"/>
                        <telerik:RadButton Content="🔄 Refresh"
                            Click="RefreshControls_Click"/>
                    </WrapPanel>
                </Grid>
            </telerik:RadTabItem>

        </telerik:RadTabControl>

        <!-- ── Footer ───────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#FFF5F5F5"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <DockPanel>
                <telerik:RadButton DockPanel.Dock="Right"
                    Content="Close" Width="80"
                    Click="Close_Click"/>
                <TextBlock x:Name="StatusText"
                    VerticalAlignment="Center" FontSize="11"
                    Foreground="#FF555555"
                    Text="Edit any cell — changes persist to miniIDE.db on Save Changes"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
