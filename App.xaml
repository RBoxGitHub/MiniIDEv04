<Application x:Class="MiniIDEv04.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:conv="clr-namespace:MiniIDEv04.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <telerik:Windows11ResourceDictionary/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Converters ──────────────────────────────────────── -->
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
            <conv:IntOffsetConverter      x:Key="IntOffsetConverter"/>

            <!-- ── FilterToggleStyle — pill ToggleButton ───────────── -->
            <Style x:Key="FilterToggleStyle" TargetType="ToggleButton">
                <Setter Property="Height"          Value="22"/>
                <Setter Property="Padding"         Value="10,0"/>
                <Setter Property="FontSize"        Value="11"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="border"
                                    CornerRadius="11"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Background"  Value="#F0F0F0"/>
                <Setter Property="BorderBrush" Value="#BBBBBB"/>
                <Setter Property="Foreground"  Value="#555555"/>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background"  Value="#FF1565C0"/>
                        <Setter Property="BorderBrush" Value="#FF1565C0"/>
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="FontWeight"  Value="SemiBold"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ── Add button style — use Style="{StaticResource AddButtonStyle}" ── -->
            <Style x:Key="AddButtonStyle" TargetType="telerik:RadButton">
                <Setter Property="Background"   Value="#FF90EE90"/>
                <Setter Property="Foreground"   Value="#FF1B5E20"/>
                <Setter Property="FontWeight"   Value="SemiBold"/>
                <Setter Property="FontSize"     Value="11"/>
                <Setter Property="Padding"      Value="10,4"/>
                <Setter Property="BorderBrush"  Value="#FF66BB6A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor"       Value="Hand"/>
            </Style>

            <!-- ── GroupHeaderRow style — light blue to match alternating rows ── -->
            <Style x:Key="BlueGroupRowStyle" TargetType="telerik:GroupHeaderRow">
                <Setter Property="Background" Value="#FFD6EAF8"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
